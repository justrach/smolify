{
  "name": "smolify",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview --env local",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf:build": "opennextjs-cloudflare build",
    "cf:types": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "db:migrate:local": "wrangler d1 migrations apply smolify-db --local --env local",
    "db:migrate:remote": "wrangler d1 migrations apply smolify-db --remote",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:retrieval-parity": "vitest run lib/evals/retrieval-parity.test.ts lib/imports/source-analysis.test.ts lib/imports/public-symbols.test.ts lib/docs/context.test.ts lib/docs/source-context.test.ts lib/docs/search-repository.test.ts lib/mcp/auth.test.ts lib/mcp/server.test.ts",
    "test:retrieval-parity:live": "SMOLIFY_LIVE_PARITY=1 vitest run lib/evals/retrieval-parity.live.test.ts",
    "test:e2e:mcp": "node scripts/e2e-mcp.mjs",
    "test:e2e:community": "node scripts/e2e-community.mjs"
  },
  "dependencies": {
    "@better-auth/oauth-provider": "^1.7.0-rc.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opennextjs/cloudflare": "1.20.1",
    "better-auth": "^1.7.0-rc.1",
    "fflate": "^0.8.2",
    "github-slugger": "2.0.0",
    "hast-util-sanitize": "5.0.2",
    "kysely": "0.28.17",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "rehype-sanitize": "6.0.0",
    "rehype-stringify": "10.0.1",
    "remark-gfm": "4.0.1",
    "remark-parse": "11.0.0",
    "remark-rehype": "11.1.2",
    "unified": "11.0.5",
    "unist-util-visit": "5.1.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "eslint": "9.39.1",
    "eslint-config-next": "16.2.10",
    "typescript": "5.9.3",
    "vitest": "4.1.10",
    "wrangler": "4.112.0"
  },
  "overrides": {
    "postcss": "8.5.19"
  }
}
