{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://app.smol.ly/schemas/bundle-v1.json",
  "title": "Smolify documentation bundle",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "project", "generatedAt", "generator", "navigation", "pages"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description", "accent"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 80 },
        "description": { "type": "string", "maxLength": 240 },
        "accent": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" }
      }
    },
    "generatedAt": { "type": "string", "format": "date-time" },
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "model"],
      "properties": {
        "name": { "const": "codex" },
        "model": { "type": "string", "minLength": 1, "maxLength": 80 }
      }
    },
    "navigation": {
      "type": "array",
      "minItems": 1,
      "maxItems": 30,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "items"],
        "properties": {
          "label": { "type": "string", "minLength": 1, "maxLength": 80 },
          "items": {
            "type": "array",
            "minItems": 1,
            "maxItems": 100,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["label", "slug"],
              "properties": {
                "label": { "type": "string", "minLength": 1, "maxLength": 80 },
                "slug": { "$ref": "#/$defs/slug" }
              }
            }
          }
        }
      }
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "maxItems": 500,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["slug", "title", "description", "markdown", "sourceFiles"],
        "properties": {
          "slug": { "$ref": "#/$defs/slug" },
          "title": { "type": "string", "minLength": 1, "maxLength": 120 },
          "description": { "type": "string", "maxLength": 240 },
          "markdown": { "type": "string", "minLength": 1, "maxLength": 250000 },
          "sourceFiles": {
            "type": "array",
            "maxItems": 100,
            "items": { "type": "string", "maxLength": 500 }
          }
        }
      }
    }
  },
  "$defs": {
    "slug": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160,
      "pattern": "^[a-z0-9]+(?:[/-][a-z0-9]+)*$"
    }
  }
}
